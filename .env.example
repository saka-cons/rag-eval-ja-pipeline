# 認証情報の雛形。使い方:
#   1) cp .env.example .env
#   2) .env に実値を記入（.env は .gitignore 済み・コミットしない）
#   3) 端末ごとに1回、repoルートで読み込む:
#        set -a; source .env; set +a
#   4) その後にスクリプトを実行（例: python3 scripts/02_generate_answers.py）
#
# 値は Dify の各画面「APIアクセス」で発行する。
DIFY_KNOWLEDGE_API_KEY=dataset-xxxx   # ナレッジ(dataset)APIキー: 01 / 01_vlm / wait_indexing / diag / validate / fix 用
DIFY_APP_API_KEY=app-xxxx             # チャットアプリAPIキー: 02_generate_answers / del_history 用
# LM_API_TOKEN=                       # LM Studio 認証時のみ（通常は空でよい）
