# 認証情報の雛形。使い方:
#   1) cp .env.example .env
#   2) .env に実値を記入（.env は .gitignore 済み・コミットしない）
#   3) 端末ごとに1回、repoルートで読み込む:
#        set -a; source .env; set +a
#   4) その後にスクリプトを実行（例: python3 scripts/02_generate_answers.py）
#
# 接続先
DIFY_BASE_URL=http://localhost
LMSTUDIO_API=http://localhost:1234
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Dify APIキー
DIFY_KNOWLEDGE_API_KEY=dataset-xxxx   # ナレッジ(dataset)APIキー: 取込 / indexing待機 / retrieval検証 用
DIFY_ADMIN_API_KEY=console-access-token-xxxx  # 互換用。DIFY_CONSOLE_ACCESS_TOKEN があればそちらを優先。
# self-hosted DifyのConsole API用。ローカルDocker Difyではrunnerが短期tokenを自動生成する。
# DIFY_CONSOLE_ACCESS_TOKEN=
# DIFY_CONSOLE_CSRF_TOKEN=
# DIFY_DOCKER_COMPOSE=../dify_rag/dify/docker/docker-compose.yaml
# DIFY_CONSOLE_ACCOUNT_ID=
# DIFY_CONSOLE_TOKEN_TTL_SECONDS=7200
DIFY_APP_API_KEY=app-xxxx             # 既存単体appを使う場合のみ。自動runnerはrun別キーを生成して使う。

# Dify / LM Studio モデル名
DIFY_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B-GGUF
DIFY_EMBEDDING_PROVIDER=stvlynn/lmstudio/lmstudio
VLM_MODEL=qwen/qwen3-vl-8b

# LM Studio 認証時のみ（通常は空でよい）
# LM_API_TOKEN=
